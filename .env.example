# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string — Supabase recommended (persistent free tier),
# or local Docker for testing. Avoid Render's free Postgres — it expires after 30 days.
DATABASE_URL=postgresql://postgres:your-password@db.xxxxxxxx.supabase.co:5432/postgres

# Anthropic API key for the extraction/policy-check/draft agents
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — defaults to claude-sonnet-5 if unset
ANTHROPIC_MODEL=claude-sonnet-5

# Flask session secret — generate a real random value for anything beyond local dev
SECRET_KEY=dev-only-change-me
